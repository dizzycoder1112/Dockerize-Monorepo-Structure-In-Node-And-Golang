{
  "compilerOptions": {
    "moduleResolution": "nodenext",
    "module": "NodeNext",
    "target": "ES2022",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "lib": ["DOM", "ESNext.Object", "ES2022"]
  },
  "include": ["ts-packages/**/*", "apps/**/*"],
  "exclude": ["**/*.spec.ts", "node_modules"]
}
